{
  "name": "@firebird1998/d3charts-react",
  "version": "0.1.0",
  "description": "React charting library powered by D3 — BarChart, LineChart, PieChart with TypeScript support",
  "license": "MIT",
  "author": "Ankit Das (FireBird1998)",
  "repository": {
    "type": "git",
    "url": "https://github.com/FireBird1998/d3Charts-React.git",
    "directory": "packages/chart-lib"
  },
  "homepage": "https://github.com/FireBird1998/d3Charts-React",
  "keywords": [
    "react",
    "d3",
    "charts",
    "bar-chart",
    "line-chart",
    "pie-chart",
    "data-visualization",
    "svg",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "d3-array": "^3.2.0",
    "d3-scale": "^4.0.0",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.6.15",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/d3-array": "^3.2.0",
    "@types/d3-scale": "^4.0.0",
    "@types/d3-shape": "^3.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild-sass-plugin": "^3.6.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sass": "^1.97.3",
    "storybook": "^8.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
